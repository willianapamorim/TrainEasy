{
  "expo": {
    "name": "TrainEasy",
    "slug": "TrainEasy",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "traineasy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/image.png",
    "splash": {
      "image": "./assets/images/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.willianamorim.traineasy"
    },
    "android": {
      "package": "com.willianamorim.traineasy",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/image.png",
        "backgroundColor": "#7C3AED"
      },
      "navigationBar": {
        "visible": "sticky-immersive"
      }
    },
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "#00000000",
      "barStyle": "light-content"
    },
    "web": {
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76189774-bfa8-4f5e-8f74-f4c20d823c85"
      }
    }
  }
}
